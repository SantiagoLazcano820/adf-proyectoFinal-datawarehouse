{
	"name": "df_gold_dim_catalogo_paquetes",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          paquete_id as integer,",
				"          nombre_paquete as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    cp.paquete_id,\\n    MAX(cp.nombre) AS nombre_paquete,\\n    MAX(cp.contenido) AS contenido,\\n    MAX(cp.peso_estandar_kg) AS peso_estandar_kg,\\n    MAX(cp.costo_estimado_bs) AS costo_estimado_bs\\nFROM silver.tbl_catalogo_paquetes cp\\nLEFT JOIN silver.tbl_entregas_subsidio es ON cp.paquete_id = es.paquete_id\\nWHERE cp.paquete_id IS NOT NULL\\nGROUP BY cp.paquete_id',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_key as integer,",
				"          paquete_id as integer,",
				"          nombre_paquete as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre_paquete,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sink1"
			]
		}
	}
}