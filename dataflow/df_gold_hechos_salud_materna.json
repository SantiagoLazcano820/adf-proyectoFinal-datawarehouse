{
	"name": "df_gold_hechos_salud_materna",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "silver_pagos",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "source5"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento",
						"type": "DatasetReference"
					},
					"name": "source6"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_salud_materna",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				},
				{
					"name": "lookup5"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(6,2),",
				"          presion_arterial as string,",
				"          resultado_medico as string,",
				"          origen_sistema as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          pago_id as integer,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre_establecimiento as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source6",
				"source1, source2 lookup(source1@ci_beneficiaria == source2@ci_beneficiaria,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, source4 lookup(fecha_control == fecha,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3, source5 lookup(source1@ci_beneficiaria == ci,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4",
				"lookup4, source6 lookup(source1@establecimiento_id == source6@establecimiento_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup5",
				"derivedColumn2 select(mapColumn(",
				"          control_id,",
				"          nro_control_prenatal = nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          monto_pago_bs = monto_bs,",
				"          fecha_key,",
				"          beneficiaria_key = persona_key,",
				"          establecimiento_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"lookup5 derive(persona_key = iifNull(persona_key, -1),",
				"          monto_bs = iifNull(monto_bs, toDecimal(0.00, 10, 2)),",
				"          fecha_key = iifNull(fecha_key, -1)) ~> derivedColumn2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          hecho_materno_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          control_id as integer,",
				"          semana_gestacion as integer,",
				"          nro_control_prenatal as integer,",
				"          peso_madre_kg as decimal(6,2),",
				"          presion_arterial as string,",
				"          monto_pago_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          beneficiaria_key,",
				"          establecimiento_key,",
				"          control_id,",
				"          semana_gestacion,",
				"          nro_control_prenatal,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          monto_pago_bs",
				"     )) ~> sink1"
			]
		}
	}
}