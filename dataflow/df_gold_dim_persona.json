{
	"name": "df_gold_dim_persona",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_personas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(6,2),",
				"          talla_nacimiento_cm as decimal(6,2),",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    p.ci,\\n    CONCAT(MAX(p.nombres), \\' \\', ISNULL(MAX(p.ap_paterno), \\'\\'), \\' \\', ISNULL(MAX(p.ap_materno), \\'\\')) AS nombres_completos,\\n    MAX(p.genero) AS genero,\\n    MAX(p.fecha_nac) AS fecha_nacimiento,\\n    MAX(p.municipio_residencia) AS municipio_residencia,\\n    MAX(p.nivel_estudios) AS nivel_estudios,\\n    MAX(p.profesion) AS profesion,\\n    \\n    -- Campos de Parto (Vienen de silver.tbl_partos)\\n    MAX(pa.tipo_parto) AS tipo_parto,\\n    MAX(pa.peso_nacimiento_kg) AS peso_nacimiento_kg,\\n    MAX(pa.talla_nacimiento_cm) AS talla_nacimiento_cm,\\n    \\n    -- Campos de Inscripción (Vienen de silver.tbl_inscripciones)\\n    MAX(i.inscripcion_id) AS inscripcion_id,\\n    MAX(i.fecha_inscripcion) AS fecha_inscripcion\\nFROM silver.tbl_personas p\\nLEFT JOIN silver.tbl_partos pa ON p.ci = pa.ci_recien_nacido\\nLEFT JOIN silver.tbl_inscripciones i ON p.ci = i.ci_beneficiaria\\nWHERE p.ci IS NOT NULL\\nGROUP BY p.ci',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(6,2),",
				"          talla_nacimiento_cm as decimal(6,2),",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres_completos,",
				"          genero,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          nivel_estudios,",
				"          profesion,",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm,",
				"          inscripcion_id,",
				"          fecha_inscripcion",
				"     )) ~> sink1"
			]
		}
	}
}