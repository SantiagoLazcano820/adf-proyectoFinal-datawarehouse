{
	"name": "df_gold_dim_persona",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_personas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    ISNULL(p.ci, pa.ci_recien_nacido) AS ci,\\n    CASE \\n        WHEN MAX(p.nombres) IS NOT NULL \\n        THEN CONCAT(MAX(p.nombres), \\' \\', ISNULL(MAX(p.ap_paterno), \\'\\'), \\' \\', ISNULL(MAX(p.ap_materno), \\'\\'))\\n        ELSE \\'Recién Nacido (Data Transaccional)\\'\\n    END AS nombres_completos,\\n    ISNULL(MAX(p.genero), \\'N/D\\') AS genero,\\n    ISNULL(MAX(p.fecha_nac), MAX(pa.fecha_parto)) AS fecha_nacimiento,\\n    MAX(p.municipio_residencia) AS municipio_residencia,\\n    MAX(p.nivel_estudios) AS nivel_estudios,\\n    MAX(p.profesion) AS profesion,\\n    MAX(i.inscripcion_id) AS inscripcion_id,\\n    MAX(i.fecha_inscripcion) AS fecha_inscripcion\\nFROM silver.tbl_personas p\\nFULL OUTER JOIN silver.tbl_partos pa ON p.ci = pa.ci_recien_nacido\\nLEFT JOIN silver.tbl_inscripciones i ON ISNULL(p.ci, pa.ci_recien_nacido) = i.ci_beneficiaria\\nWHERE p.ci IS NOT NULL OR pa.ci_recien_nacido IS NOT NULL\\nGROUP BY \\n    ISNULL(p.ci, pa.ci_recien_nacido)',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres_completos,",
				"          genero,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          nivel_estudios,",
				"          profesion,",
				"          inscripcion_id,",
				"          fecha_inscripcion",
				"     )) ~> sink1"
			]
		}
	}
}