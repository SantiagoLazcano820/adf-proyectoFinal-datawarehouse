{
	"name": "df_gold_hechos_entregas_subsidio",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_entregas_subsidio",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "source5"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_entregas_subsidio",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          nro_boleta as string,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(10,2),",
				"          fecha_proxima_entrega as date,",
				"          estado_boleta as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombres_completos as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string,",
				"          profesion as string,",
				"          inscripcion_id as integer,",
				"          fecha_inscripcion as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre_establecimiento as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          paquete_key as integer,",
				"          paquete_id as integer,",
				"          nombre_paquete as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source1, source2 lookup(fecha_entrega == fecha,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, source3 lookup(ci_beneficiaria == ci,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, source4 lookup(source1@establecimiento_id == source4@establecimiento_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3, source5 lookup(source1@paquete_id == source5@paquete_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4",
				"lookup4 select(mapColumn(",
				"          entrega_id,",
				"          nro_boleta_subsidio = nro_boleta,",
				"          peso_paquete_entregado_kg = peso_paquete_kg,",
				"          estado_boleta_subsidio = estado_boleta,",
				"          fecha_key,",
				"          beneficiaria_key = persona_key,",
				"          establecimiento_key,",
				"          paquete_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(beneficiaria_key = iifNull(beneficiaria_key, -1),",
				"          fecha_key = iifNull(fecha_key, -1)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          hecho_entrega_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          paquete_key as integer,",
				"          entrega_id as integer,",
				"          nro_boleta_subsidio as string,",
				"          estado_boleta_subsidio as string,",
				"          peso_paquete_entregado_kg as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          beneficiaria_key,",
				"          establecimiento_key,",
				"          paquete_key,",
				"          entrega_id,",
				"          nro_boleta_subsidio,",
				"          estado_boleta_subsidio,",
				"          peso_paquete_entregado_kg",
				"     )) ~> sink1"
			]
		}
	}
}