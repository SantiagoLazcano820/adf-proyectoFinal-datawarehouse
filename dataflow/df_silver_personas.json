{
	"name": "df_silver_personas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_segip_personas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_personas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          ap_paterno as string,",
				"          ap_materno as string,",
				"          fecha_nac as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(ci) AS ci,\\n    TRIM(nombres) AS nombres,\\n    TRIM(ap_paterno) AS ap_paterno,\\n    TRIM(ap_materno) AS ap_materno,\\n    TRIM(fecha_nacimiento) AS fecha_nac,\\n    TRIM(genero) AS genero,\\n    TRIM(estado_civil) AS estado_civil,\\n    TRIM(ci_conyuge) AS ci_conyuge,\\n    TRIM(numero_hijos) AS numero_hijos,\\n    TRIM(ci_padre) AS ci_padre,\\n    TRIM(ci_madre) AS ci_madre,\\n    TRIM(profesion) AS profesion,\\n    TRIM(nivel_estudios) AS nivel_estudios,\\n    TRIM(municipio_residencia) AS municipio_residencia,\\n    TRIM(fecha_emision) AS fecha_emision\\nFROM bronze.tbl_segip_personas\\nWHERE ci IS NOT NULL AND TRIM(ci) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(fecha_nac = toDate(fecha_nac),",
				"          fecha_emision = toDate(fecha_emision),",
				"          numero_hijos = toInteger(numero_hijos),",
				"          columna1 = ERROR_FUNCTION('')) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ci as string,",
				"          nombres as string,",
				"          ap_paterno as string,",
				"          ap_materno as string,",
				"          fecha_nac as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as integer,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as date,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres,",
				"          ap_paterno,",
				"          ap_materno,",
				"          fecha_nac,",
				"          genero,",
				"          estado_civil,",
				"          ci_conyuge,",
				"          numero_hijos,",
				"          ci_padre,",
				"          ci_madre,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia,",
				"          fecha_emision",
				"     )) ~> sink1"
			]
		}
	}
}